{
  "manifest_version": 3,
  "name": "ByPass Ai",
  "version": "6.4.4",
  "description": "ByPass Ai — smart automation and AI-powered tools for Lovable.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel",
    "cookies"
  ],
  "host_permissions": [
    "https://*.lovable.dev/*",
    "https://api.lovable.dev/*",
    "https://lovable.dev/*",
    "https://lovable-api.com/*",
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://lov.powerkits.net/*",
    "https://*.vercel.app/*",
    "https://replit.com/*",
    "https://*.replit.com/*"
  ],
  "action": {
    "default_title": "Lovable Powerkits",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lovable.dev/*",
        "https://lovable.dev/*"
      ],
      "js": [
        "pageHook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.lovable.dev/*",
        "https://lovable.dev/*",
        "https://api.lovable.dev/*"
      ],
      "js": [
        "extension-config.js",
        "platform-config.js",
        "lovable-auth.js",
        "lovable-feature-api.js",
        "user-messages.js",
        "jszip.min.js",
        "hwFingerprint.js",
        "license-guard.js",
        "content-bridge.js",
        "sounds.js",
        "content-templates.js",
        "content.js"
      ],
      "css": [
        "theme.css",
        "floating.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "extension-config.js",
        "platform-config.js",
        "hwFingerprint.js",
        "license-guard.js",
        "user-messages.js",
        "chatgpt-bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://replit.com/*",
        "https://*.replit.com/*"
      ],
      "js": [
        "extension-config.js",
        "platform-config.js",
        "hwFingerprint.js",
        "license-guard.js",
        "user-messages.js",
        "replit-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pageHook.js",
        "sounds/error-payment.mp3",
        "sounds/error-ratelimit.mp3",
        "sounds/error-token.mp3",
        "assets/logo-master-lovable.png",
        "assets/logo-master-lovable-square.png",
        "assets/icon16.png",
        "assets/icon32.png",
        "assets/icon48.png",
        "assets/icon128.png"
      ],
      "matches": [
        "https://*.lovable.dev/*",
        "https://lovable.dev/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}